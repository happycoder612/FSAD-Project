        function switchTab(tab) {
            const loginTab = document.getElementById('loginTab');
            const registerTab = document.getElementById('registerTab');
            const loginForm = document.getElementById('loginForm');
            const registerForm = document.getElementById('registerForm');
            const modalTitle = document.getElementById('modalTitle');
            const modalSubtitle = document.getElementById('modalSubtitle');

            clearErrors();

            if (tab === 'login') {
                loginTab.classList.add('active');
                registerTab.classList.remove('active');
                loginForm.classList.remove('hidden');
                registerForm.classList.add('hidden');
                modalTitle.textContent = 'Welcome Back';
                modalSubtitle.textContent = 'Sign in to continue your learning journey';
            } else {
                registerTab.classList.add('active');
                loginTab.classList.remove('active');
                registerForm.classList.remove('hidden');
                loginForm.classList.add('hidden');
                modalTitle.textContent = 'Create Account';
                modalSubtitle.textContent = 'Start your journey to becoming a full-stack developer';
            }
        }

        // Password Toggle
        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            input.type = input.type === 'password' ? 'text' : 'password';
        }

        // Form Validation
        function validateEmail(email) {
            return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
        }

        function validatePassword(password) {
            const hasMinLength = password.length >= 8;
            const hasUppercase = /[A-Z]/.test(password);
            const hasNumber = /[0-9]/.test(password);
            const hasSpecial = /[!@#$%^&*(),.?":{}|<>]/.test(password);
            return hasMinLength && hasUppercase && hasNumber && hasSpecial;
        }

        function showError(elementId, show = true) {
            const element = document.getElementById(elementId);
            if (show) {
                element.classList.add('show');
                element.previousElementSibling.classList.add('error');
            } else {
                element.classList.remove('show');
                element.previousElementSibling.classList.remove('error');
            }
        }

        function clearErrors() {
            document.querySelectorAll('.error-message').forEach(el => el.classList.remove('show'));
            document.querySelectorAll('.form-group input').forEach(el => {
                el.classList.remove('error');
                el.classList.remove('success');
            });
        }

        function clearFormInputs() {
            document.getElementById('loginForm').reset();
            document.getElementById('registerForm').reset();
            clearErrors();
        }

        // Authentication Handlers
        function handleLogin(event) {
            event.preventDefault();
            const email = document.getElementById('loginEmail').value;
            const password = document.getElementById('loginPassword').value;

            // Get registered users
            const users = JSON.parse(localStorage.getItem('codemaster_users') || '[]');
            const user = users.find(u => u.email === email);

            if (!user) {
                showError('loginEmailError');
                showToast('Login Failed', 'No account found with this email');
                return;
            }

            if (user.password !== password) {
                showError('loginPasswordError');
                showToast('Login Failed', 'Incorrect password');
                return;
            }

            // Login successful
            currentUser = { name: user.name, email: user.email };
            enrolledCourses = user.enrolledCourses || [];
            saveUserSession();
            updateUIForLoggedInUser();
            closeModal();
            showToast('Welcome Back!', `Great to see you again, ${user.name.split(' ')[0]}!`);
        }

        function handleRegister(event) {
            event.preventDefault();
            const name = document.getElementById('registerName').value;
            const email = document.getElementById('registerEmail').value;
            const password = document.getElementById('registerPassword').value;
            const confirmPassword = document.getElementById('registerConfirmPassword').value;

            let hasError = false;

            // Validate name
            if (!name.trim()) {
                showError('registerNameError');
                hasError = true;
            }

            // Validate email
            if (!validateEmail(email)) {
                showError('registerEmailError');
                hasError = true;
            }

            // Check if email exists
            const users = JSON.parse(localStorage.getItem('codemaster_users') || '[]');
            if (users.some(u => u.email === email)) {
                showError('registerEmailError');
                showToast('Registration Failed', 'Email already registered');
                hasError = true;
            }

            // Validate password
            if (!validatePassword(password)) {
                showError('registerPasswordError');
                hasError = true;
            }

            // Validate confirm password
            if (password !== confirmPassword) {
                showError('registerConfirmError');
                hasError = true;
            }

            if (hasError) return;

            // Create new user
            const newUser = {
                name,
                email,
                password,
                enrolledCourses: [],
                createdAt: new Date().toISOString()
            };

            users.push(newUser);
            localStorage.setItem('codemaster_users', JSON.stringify(users));

            // Auto login
            currentUser = { name: newUser.name, email: newUser.email };
            enrolledCourses = [];
            saveUserSession();
            updateUIForLoggedInUser();
            closeModal();
            showToast('Account Created!', 'Welcome to CodeMaster Academy!');
        }

        function logout() {
            currentUser = null;
            enrolledCourses = [];
            localStorage.removeItem('codemaster_user');
            localStorage.removeItem('codemaster_enrolled');
            
            document.getElementById('authButtons').classList.remove('hidden');
            document.getElementById('userMenu').classList.remove('active');
            
            showToast('Logged Out', 'You have been successfully logged out');
            
            // Return to home view
            document.getElementById('home').classList.remove('hidden');
            document.querySelector('.categories').classList.remove('hidden');
            document.querySelector('.features').classList.remove('hidden');
            document.querySelector('.testimonials').classList.remove('hidden');
            document.querySelector('footer').classList.remove('hidden');
        }

        // Course Functions
        function renderCourses() {
            const grid = document.getElementById('coursesGrid');
            const filtered = courses.filter(course => {
                const matchesCategory = currentFilter === 'all' || course.category === currentFilter;
                const matchesSearch = course.title.toLowerCase().includes(currentSearch.toLowerCase()) ||
                                     course.instructor.toLowerCase().includes(currentSearch.toLowerCase());
                return matchesCategory && matchesSearch;
            });

            if (filtered.length === 0) {
                grid.innerHTML = `
                    <div class="no-courses" style="grid-column: 1/-1;">
                        <div class="no-courses-icon">🔍</div>
                        <h3>No courses found</h3>
                        <p>Try adjusting your search or filter criteria</p>
                    </div>
                `;
                return;
            }

            grid.innerHTML = filtered.map(course => `
                <div class="course-card">
                    <div class="course-thumbnail">
                        <span class="course-badge ${course.category}">${course.category}</span>
                        ${course.icon}
                    </div>
                    <div class="course-content">
                        <div class="course-instructor">
                            👤 ${course.instructor}
                        </div>
                        <h3 class="course-title">${course.title}</h3>
                        <div class="course-meta">
                            <div class="course-rating">
                                <span class="stars">★</span>
                                <strong>${course.rating}</strong>
                                <span class="rating-count">(${course.reviews.toLocaleString()})</span>
                            </div>
                        </div>
                        <div class="course-meta">
                            <div class="course-price">
                                <span class="original">$${course.originalPrice}</span>
                                $${course.price}
                            </div>
                        </div>
                        <div class="course-footer">
                            <button class="btn btn-outline" onclick="viewCourse(${course.id})">Details</button>
                            <button class="btn btn-primary" onclick="enrollCourse(${course.id})">
                                ${isEnrolled(course.id) ? 'Continue' : 'Enroll Now'}
                            </button>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        function filterByCategory(category) {
            currentFilter = category;
            
            // Update active button
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.classList.remove('active');
                if (btn.textContent.toLowerCase() === category || 
                    (category === 'all' && btn.textContent === 'All')) {
                    btn.classList.add('active');
                }
            });

            renderCourses();
        }

        function filterCourses() {
            currentSearch = document.getElementById('searchInput').value;
            renderCourses();
        }

        function isEnrolled(courseId) {
            return enrolledCourses.some(c => c.id === courseId);
        }

        function enrollCourse(courseId) {
            if (!currentUser) {
                openModal('login');
                showToast('Login Required', 'Please login to enroll in courses');
                return;
            }

            const course = courses.find(c => c.id === courseId);
            if (!course) return;

            if (isEnrolled(courseId)) {
                showToast('Already Enrolled', 'You are already enrolled in this course');
                return;
            }

            // Add to enrolled courses
            enrolledCourses.push({
                ...course,
                enrolledAt: new Date().toISOString(),
                progress: 0
            });
            saveUserSession();
            
            renderCourses();
            showToast('Enrollment Successful!', `Welcome to "${course.title}"`);
        }

        function viewCourse(courseId) {
            const course = courses.find(c => c.id === courseId);
            if (!course) return;
            
            showToast(course.title, course.description);
        }

        // Dashboard Functions
        function showDashboard() {
            const dashboard = document.querySelector('.dashboard');
            
            if (!currentUser) {
                openModal('login');
                return;
            }

            // Hide other sections
            document.getElementById('home').classList.add('hidden');
            document.querySelector('.categories').classList.add('hidden');
            document.querySelector('.features').classList.add('hidden');
            document.querySelector('.testimonials').classList.add('hidden');
            document.querySelector('footer').classList.add('hidden');
            document.querySelector('header').classList.add('hidden');

            // Show dashboard
            dashboard.classList.add('active');
            document.body.style.paddingTop = '0';

            // Render enrolled courses
            const coursesContainer = dashboard.querySelector('.enrolled-courses');
            
            if (enrolledCourses.length === 0) {
                coursesContainer.innerHTML = `
                    <div class="no-courses" style="grid-column: 1/-1;">
                        <div class="no-courses-icon">📚</div>
                        <h3>No courses yet</h3>
                        <p>Start your learning journey by enrolling in a course</p>
                        <button class="btn btn-primary" onclick="hideDashboard()">Browse Courses</button>
                    </div>
                `;
            } else {
                coursesContainer.innerHTML = enrolledCourses.map(course => `
                    <div class="enrolled-card">
                        <div class="enrolled-icon">${course.icon}</div>
                        <div class="enrolled-info">
                            <h3>${course.title}</h3>
                            <p>${course.instructor}</p>
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: ${course.progress || 0}%"></div>
                            </div>
                            <p class="progress-text">${course.progress || 0}% Complete</p>
                        </div>
                    </div>
                `).join('');
            }
        }

        function hideDashboard() {
            const dashboard = document.querySelector('.dashboard');
            dashboard.classList.remove('active');
            
            // Show other sections
            document.getElementById('home').classList.remove('hidden');
            document.querySelector('.categories').classList.remove('hidden');
            document.querySelector('.features').classList.remove('hidden');
            document.querySelector('.testimonials').classList.remove('hidden');
            document.querySelector('footer').classList.remove('hidden');
            document.querySelector('header').classList.remove('hidden');
        }

        // Toast Notifications
        function showToast(title, message, type = 'success') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            toast.innerHTML = `
                <span class="toast-icon">${type === 'success' ? '✓' : '✕'}</span>
                <div class="toast-content">
                    <h4>${title}</h4>
                    <p>${message}</p>
                </div>
            `;
            
            container.appendChild(toast);
            
            // Auto remove
            setTimeout(() => {
                toast.style.animation = 'slideIn 0.3s ease reverse';
                setTimeout(() => toast.remove(), 300);
            }, 4000);
        }

        // Close modal on outside click
        document.getElementById('authModal').addEventListener('click', (e) => {
            if (e.target.classList.contains('modal-overlay')) {
                closeModal();
            }
        });

        // Escape key to close modal
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                closeModal();
            }
        });
    </script>
</body>
</html>

