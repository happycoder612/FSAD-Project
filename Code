            const savedUser = localStorage.getItem('codemaster_user');
            const savedEnrolled = localStorage.getItem('codemaster_enrolled');
            
            if (savedUser) {
                currentUser = JSON.parse(savedUser);
                enrolledCourses = savedEnrolled ? JSON.parse(savedEnrolled) : [];
                updateUIForLoggedInUser();
